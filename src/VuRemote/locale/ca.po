#: ../plugin.py:87
msgid "Cancel"
msgstr "Cancel·lar"

#: ../plugin.py:120
msgid "FILE NOT EXIST : /proc/stb/fp/remote_code"
msgstr "L'arxiu /proc/stb/fp/remote_code no existeix"

#: ../plugin.py:148
msgid "Keep"
msgstr "OK"

#: ../plugin.py:122
msgid "Please change your remote mode"
msgstr "Per a canviar el mode del comandament"

#: ../plugin.py:124
msgid "Press and hold '2' & '7' until red LED is solid, then press 'Help', then press '000"
msgstr "Prem i deixa premuts '2' y '7' fins que el led roig es quedi fixe, llavors prem 'Help' i després prem '000"

#: ../plugin.py:126
msgid "Press and hold <OK> and <STB> until red LED is solid, then press '0000"
msgstr "Prem y i deixa premuts <OK> i <STB> fins que el LED roig es quedi fixe, llavors prem '0000"

#: ../plugin.py:76 ../plugin.py:161 ../plugin.py:169
msgid "Remote Control Code"
msgstr "Codi comandament"

#: ../plugin.py:104
msgid "Remote Control System Code"
msgstr "Sistema del comandament"

#: ../plugin.py:103
msgid "Remote Control Type"
msgstr "Tipus comandament"

#: ../plugin.py:148
msgid "Restore"
msgstr "Restaurar"

#: ../plugin.py:88
msgid "Save"
msgstr "Guardar"

#: ../plugin.py:99
#, python-format
msgid "Sorry, but %s is not supported."
msgstr "Ho sentim, però %s no està suportat."

#: ../plugin.py:108
msgid "Text support"
msgstr "Text de suport"

#: ../plugin.py:127
msgid "Then choose 'Keep' within seconds"
msgstr "A continuació premi 'OK'"
