msgstr "Ce fichier n'existe pas: /proc/stb/fp/remote_code"

#: ../plugin.py:148
msgid "Keep"
msgstr "Garder"

#: ../plugin.py:122
msgid "Please change your remote mode"
msgstr "Veuillez changer le mode télécommande"

#: ../plugin.py:124
msgid "Press and hold '2' & '7' until red LED is solid, then press 'Help', then press '000"
msgstr "Appuyer et tenir '2' & '7' jusqu’à ce que la LED soit rouge fixe, puis appuyez 'Help', ensuite appuyez '000"

#: ../plugin.py:126
msgid "Press and hold <OK> and <STB> until red LED is solid, then press '0000"
msgstr "Appuyez et maintenez <OK> et <STB> jusqu'à ce que la LED rouge soit fixe, puis appuyez sur ‘0000"

