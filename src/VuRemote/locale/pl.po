msgid "Keep"
msgstr "Zachowaj"

#: ../plugin.py:122
msgid "Please change your remote mode"
msgstr "Zmień swój tryb pilota"

#: ../plugin.py:124
msgid "Press and hold '2' & '7' until red LED is solid, then press 'Help', then press '000"
msgstr "Nacisnij i przytrzymaj '2' & '7' aż czerwona dioda LED zacznie świecić, a następnie naciśnij 'Help', a następnie '000'"

#: ../plugin.py:126
msgid "Press and hold <OK> and <STB> until red LED is solid, then press '0000"
msgstr "Naciśnij i przytrzymaj <OK> i <STB>, aż czerwona dioda LED zacznie świecić światłem ciągłym, a następnie naciśnij '0000'"

